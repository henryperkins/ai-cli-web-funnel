# Neon PostgreSQL connection (replace placeholders with your actual Neon values)
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require"

# Preferred variable name used by Forge scripts (falls back to DATABASE_URL)
FORGE_DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require"

# Optional pooled endpoint variant for high-concurrency/serverless workloads
DATABASE_URL_POOLED="postgresql://<user>:<password>@<pooled-host>/<database>?sslmode=require&channel_binding=require"

# Used by DB-backed integration tests when running against a non-Docker database
FORGE_INTEGRATION_DB_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require"

# Control-plane network binding
FORGE_HOST="127.0.0.1"
FORGE_PORT="8787"

# Require retrieval bootstrap during control-plane startup (true/false)
FORGE_REQUIRE_RETRIEVAL_BOOTSTRAP="false"

# Retrieval + semantic indexing
QDRANT_URL="https://<qdrant-host>"
QDRANT_API_KEY="<qdrant-api-key>"
QDRANT_COLLECTION="forge-packages"
EMBEDDING_MODEL="text-embedding-3-large"
EMBEDDING_DIMENSIONS="3072"
EMBEDDING_API_KEY="<embedding-api-key>"
# Optional fallback key name used by existing providers
OPENAI_API_KEY="<openai-api-key>"
# Optional override for embedding API base URL
EMBEDDING_API_BASE_URL="https://api.openai.com/v1"

# Outbox processor runtime
OUTBOX_JOB_MODE="dry-run"
OUTBOX_JOB_LIMIT="100"
OUTBOX_MAX_ATTEMPTS="5"
OUTBOX_RETRY_BACKOFF_SECONDS="60"
OUTBOX_INTERNAL_DISPATCH="false"
OUTBOX_DISPATCH_ENDPOINT="https://<dispatch-endpoint>"
OUTBOX_DISPATCH_BEARER_TOKEN="<dispatch-token>"
OUTBOX_RANKING_SYNC_LIMIT="100"
OUTBOX_DEAD_LETTER_LIMIT="100"

# Runtime feature flags (accepted booleans: 1,true,yes,on,0,false,no,off)
FORGE_RUNTIME_LOCAL_SUPERVISOR_ENABLED="true"
FORGE_RUNTIME_REMOTE_SSE_ENABLED="false"
FORGE_RUNTIME_REMOTE_STREAMABLE_HTTP_ENABLED="false"
FORGE_RUNTIME_SCOPE_SIDECAR_OWNERSHIP_ENABLED="true"
FORGE_RUNTIME_HARDCODED_VSCODE_PROFILE_PATH="false"

# Runtime remote connector config
FORGE_RUNTIME_REMOTE_SSE_URL="https://<remote-sse-endpoint>"
FORGE_RUNTIME_REMOTE_STREAMABLE_HTTP_URL="https://<remote-http-endpoint>"
FORGE_RUNTIME_REMOTE_AUTH_TYPE="bearer"
FORGE_RUNTIME_REMOTE_SECRET_REF="sec://remote-auth"
FORGE_RUNTIME_REMOTE_AUTH_HEADER_NAME="x-api-key"
FORGE_RUNTIME_SECRET_REFS_JSON="{\"sec://remote-auth\":\"<secret-value>\"}"

# Local development stack (docker-compose)
FORGE_LOCAL_DB_URL="postgresql://forge:forge_local@localhost:5432/forge_dev"
QDRANT_LOCAL_URL="http://localhost:6333"

# SLO rollup operator (scripts/run-slo-rollup.mjs)
SLO_ROLLUP_MODE="dry-run"
SLO_ROLLUP_LIMIT="100"
