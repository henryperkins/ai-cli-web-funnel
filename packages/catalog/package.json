{
  "name": "@forge/catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./postgres-adapters": {
      "types": "./src/postgres-adapters.ts",
      "default": "./dist/postgres-adapters.js"
    },
    "./sources/github-connector": {
      "types": "./src/sources/github-connector.ts",
      "default": "./dist/sources/github-connector.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests"
  }
}
